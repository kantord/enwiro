{
  "manifest_version": 3,
  "name": "enwiro",
  "version": "0.1.0",
  "description": "Activate enwiro environments from the web pages they belong to",
  "key": "",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "enwiro"
  },
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs",
    "notifications",
    "webNavigation"
  ]
}
