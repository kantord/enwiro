{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "minimumReleaseAge": "3 days",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Tag-tracking actions (non-semver refs) only get digest updates, which have no release timestamp, so the age gate would block them forever",
      "matchDepNames": ["dtolnay/rust-toolchain", "taiki-e/install-action"],
      "matchUpdateTypes": ["digest"],
      "minimumReleaseAge": null
    },
    {
      "description": "Patch updates are low-review-effort; land them as one PR",
      "matchUpdateTypes": ["patch"],
      "groupName": "patch updates"
    }
  ]
}
